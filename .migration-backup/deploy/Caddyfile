{
        email {$ACME_EMAIL}
}

{$SITE_ADDRESS} {
        encode gzip zstd

        # API server (keeps the /api prefix)
        handle /api/* {
                reverse_proxy api:8080
        }

        # Admin panel served under /barakat-admin/
        redir /barakat-admin /barakat-admin/
        handle /barakat-admin/* {
                root * /srv
                try_files {path} /barakat-admin/index.html
                file_server
        }

        # Main public site served at the domain root
        handle {
                root * /srv/barakat
                try_files {path} /index.html
                file_server
        }
}
