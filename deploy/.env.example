# ---- Скопируйте этот файл в .env и заполните значения ----
# cp .env.example .env

# Домен (можно указать несколько адресов через пробел)
SITE_ADDRESS=barakat-estate.tj www.barakat-estate.tj

# Email для уведомлений Let's Encrypt (выпуск HTTPS-сертификата)
ACME_EMAIL=admin@barakat-estate.tj

# База данных PostgreSQL
POSTGRES_USER=barakat
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_НАДЁЖНЫЙ_ПАРОЛЬ
POSTGRES_DB=barakat

# Секрет для подписи JWT-токенов админки.
# Сгенерируйте командой: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ

# Telegram-уведомления о заявках (необязательно — оставьте пустым, если не нужно)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ключ Yandex Maps JS API — для карт на сайте.
# Получить: https://developer.tech.yandex.ru/ (тип «JavaScript API и HTTP Геокодер»).
# Это ПУБЛИЧНЫЙ клиентский ключ — он вшивается в код сайта и виден в браузере.
# Защищайте его не секретностью, а привязкой к домену: в кабинете Yandex укажите
# barakat-estate.tj и www.barakat-estate.tj — тогда чужой сайт ключом не воспользуется.
# Ключ вшивается в статическую сборку сайта на этапе build (docker compose build).
# Оставьте пустым — карты просто не будут отображаться (без ошибок в консоли).
VITE_YANDEX_MAPS_API_KEY=
